---
import Layout from "../layouts/Layout.astro";
const env = Astro.locals?.cloudflare?.env || Astro.locals?.runtime?.env || (import.meta as any).env || {};
const RAZORPAY_KEY_ID = env.RAZORPAY_KEY_ID || "";

// SEO FAQ Schema specifically for the Booking Page
const bookingFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "What is the advance payment for booking at Dolphin House?",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "We require a 50% advance payment via our secure Razorpay gateway to confirm your room. The remaining balance can be paid at the resort during check-in."
    }
  }, {
    "@type": "Question",
    "name": "How far is Dolphin House from Nagaon Beach?",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "Dolphin House is located just a 2-minute walk (approx 200 meters) from the main Nagaon Beach."
    }
  }]
};
---

