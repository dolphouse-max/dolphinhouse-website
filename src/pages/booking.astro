---
import Layout from "../layouts/Layout.astro";
const env = Astro.locals?.cloudflare?.env || Astro.locals?.runtime?.env || (import.meta as any).env || {};
const RAZORPAY_KEY_ID = env.RAZORPAY_KEY_ID || "";

// SEO FAQ Schema specifically for the Booking Page
const bookingFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "What is the advance payment for booking at Dolphin House?",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "We require a 50% advance payment via our secure Razorpay gateway to confirm your room. The remaining balance can be paid at the resort during check-in."
    }
  }, {
    "@type": "Question",
    "name": "How far is Dolphin House from Nagaon Beach?",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "Dolphin House is located just a 2-minute walk (approx 200 meters) from the main Nagaon Beach."
    }
  }]
};
---

<Layout 
  title="Book Rooms in Nagaon Alibaug | Dolphin House Beach Resort - Best Rates" 
  description="Check availability and book rooms at Dolphin House Beach Resort near Nagaon Beach, Alibaug. Secure your stay with direct booking and instant payment options." 
  image="/uploader/hotel-front-1.webp" 
  ogType="hotel"
  faqSchema={bookingFaq}
>

<section class="max-w-4xl mx-auto bg-white p-8 rounded-2xl shadow-lg mt-10 mb-20">

  <div class="flex justify-around items-center py-4 bg-sky-50 rounded-t-xl border-b border-sky-100 -mt-8 -mx-8 mb-8">
    <div class="text-center">
      <span class="block text-xl">🛡️</span>
      <span class="text-[10px] font-bold uppercase text-sky-800 tracking-tighter text-wrap">Secure Payment</span>
    </div>
    <div class="text-center">
      <span class="block text-xl">🌊</span>
      <span class="text-[10px] font-bold uppercase text-sky-800 tracking-tighter">2 Min to Beach</span>
    </div>
    <div class="text-center">
      <span class="block text-xl">⭐</span>
      <span class="text-[10px] font-bold uppercase text-sky-800 tracking-tighter">4.1/5 Google Rating</span>
    </div>
  </div>

<h1 class="text-3xl font-bold text-center mb-6">
Check Availability & Book
</h1>

<div id="errorBox" class="hidden bg-red-100 text-red-700 p-3 rounded mb-4 text-center"></div>

<div id="razorpayKeyId" data-key={RAZORPAY_KEY_ID}></div>

<div class="space-y-4 mb-8">

  <div>
    <label class="block text-sm font-medium mb-1">Number of Guests</label>
    <input id="guestCount" type="number" min="1" value="2"
      class="w-full border px-3 py-2 rounded"/>
  </div>

  <div>
    <label class="block text-sm font-medium mb-1">Number of Rooms</label>
    <input id="roomCount" type="number" min="1" value="1"
      class="w-full border px-3 py-2 rounded"/>
  </div>

  <div>
    <label class="block text-sm font-medium mb-1">Check-in</label>
    <input id="checkin" type="date"
      class="w-full border px-3 py-2 rounded"/>
  </div>

  <div>
    <label class="block text-sm font-medium mb-1">Check-out</label>
    <input id="checkout" type="date"
      class="w-full border px-3 py-2 rounded"/>
  </div>

  <button id="checkBtn"
    class="w-full bg-sky-600 text-white py-3 rounded-lg font-semibold">
    Check Availability
  </button>

</div>

<div id="availabilitySection" class="hidden mt-6">
  <h2 class="text-xl font-semibold mb-4 text-center">
    Available Room Types
  </h2>
  <div id="roomList" class="grid gap-4"></div>
</div>

<div id="guestFormSection" class="hidden mt-8 border p-6 rounded-xl bg-white shadow">
  <h3 class="text-xl font-semibold mb-4">Guest Details</h3>

  <div class="space-y-3">
    <input id="guestName" type="text" placeholder="Full Name"
      class="w-full border px-3 py-2 rounded"/>

    <div class="relative">
      <input id="guestMobile" type="tel" placeholder="Mobile Number (10 digits)"
        class="w-full border px-3 py-2 rounded pr-24"/>
      <button id="sendOtpBtn" 
        class="absolute right-1 top-1 bottom-1 bg-sky-100 text-sky-700 px-3 py-1 rounded text-sm font-semibold hover:bg-sky-200 transition disabled:opacity-50">
        Send OTP
      </button>
    </div>

    <div id="otpSection" class="hidden space-y-2 animate-in fade-in slide-in-from-top-1 duration-300">
      <div class="flex gap-2">
        <input id="otpInput" type="text" placeholder="Enter 6-digit OTP"
          class="flex-1 border px-3 py-2 rounded text-center tracking-[0.5em] font-mono text-lg"
          maxlength="6"/>
        <button id="verifyOtpBtn" 
          class="bg-sky-600 text-white px-4 py-2 rounded font-semibold hover:bg-sky-700 transition">
          Verify
        </button>
      </div>
      <div id="otpTimer" class="text-xs text-gray-500 text-center"></div>
    </div>

    <input id="guestEmail" type="email" placeholder="Email (optional)"
      class="w-full border px-3 py-2 rounded"/>
  </div>

  <button id="payAdvanceBtn"
    class="w-full bg-green-600 text-white py-3 rounded-lg mt-5 font-semibold opacity-50 cursor-not-allowed" disabled>
    Verify Mobile to Continue
  </button>
</div>

  <div id="summarySection" class="hidden mt-8 border p-6 rounded-xl bg-gray-50 shadow">

  <h3 class="text-xl font-semibold mb-4">Review Your Booking</h3>

  <div id="summaryContent" class="space-y-2 text-sm"></div>

  <div class="mt-6 flex gap-3">
    <button id="cancelBookingBtn"
      class="w-1/2 bg-gray-400 text-white py-3 rounded-lg font-semibold">
      Cancel
    </button>

    <button id="confirmPaymentBtn"
      class="w-1/2 bg-green-600 text-white py-3 rounded-lg font-semibold">
      Proceed to Payment
    </button>
  </div>

</div>
</section>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script is:inline>

// Date restrictions to improve UX
const today = new Date().toISOString().split('T')[0];
document.getElementById('checkin').setAttribute('min', today);
document.getElementById('checkin').addEventListener('change', (e) => {
    document.getElementById('checkout').setAttribute('min', e.target.value);
});

// Test if button exists and add event listener
document.addEventListener('DOMContentLoaded', function() {
  const payBtn = document.getElementById('payAdvanceBtn');
  console.log('Pay Advance button found:', !!payBtn);
  
  if (payBtn) {
    console.log('Adding event listener to pay button');
    payBtn.addEventListener('click', function() {
      console.log('Button clicked via addEventListener');
    });
  } else {
    console.error('Pay Advance button NOT found during DOMContentLoaded');
  }
});

if (document.getElementById('payAdvanceBtn')) {
  console.log('Pay Advance button found in main script');
} else {
  console.error('Pay Advance button NOT found in main script');
}

let selectedData=null;
let guestData=null;
let expiryInterval=null;
let currentLockId=null;
const EXPIRY_SECONDS=300; // 5 minutes

let isMobileVerified = false;
let otpResendTimer = 0;
let otpTimerInterval = null;

const errorBox=document.getElementById('errorBox');

function showError(msg){
  if (errorBox) {
    errorBox.textContent=msg;
    errorBox.classList.remove('hidden');
    errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
  } else {
    alert(msg);
  }
}

function rangesOverlap(aStart,aEnd,bStart,bEnd){
  return (aStart < bEnd) && (bStart < aEnd);
}

async function fetchInventory(){
  const res=await fetch('/api/inventory');
  return await res.json();
}

async function fetchBookings(start,end){
  const res=await fetch(`/api/bookings?start=${start}&end=${end}`);
  return await res.json();
}

function countBooked(bookings,room,ci,co){
  let c=0;
  const active=new Set(['approved','confirmed','checked_in','payment_pending']);
  bookings.forEach(b=>{
    if(!active.has(String(b.status).toLowerCase())) return;
    if(b.room!==room) return;
    if(rangesOverlap(new Date(ci),new Date(co),new Date(b.checkin),new Date(b.checkout))){
      c++;
    }
  });
  return c;
}

function calculateTotal(room,type,guests,nights,roomsRequested){

  const baseRate = type==="ac" ? room.rateAC : room.rateNonAC;
  const baseTotal = baseRate * nights * roomsRequested;

  let extraCharge=0;

  if(room.occupancy && guests > (room.occupancy * roomsRequested)){
    const extraPersons = guests - (room.occupancy * roomsRequested);
    extraCharge = extraPersons * room.extraPerson * nights;
  }

  return {
    baseTotal,
    extraCharge,
    grandTotal: baseTotal+extraCharge
  };
}

function startExpiryTimer(expiryDateStr) {
  if (expiryInterval) clearInterval(expiryInterval);
  
  const expiryTime = expiryDateStr ? new Date(expiryDateStr).getTime() : Date.now() + EXPIRY_SECONDS * 1000;

  const timerEl = document.getElementById('expiryTimer') || document.createElement('div');
  timerEl.id = "expiryTimer";
  timerEl.className = "text-red-600 font-semibold mt-3 p-3 bg-red-50 rounded-lg text-center border border-red-100";
  
  const summaryContent = document.getElementById('summaryContent');
  if (summaryContent && !document.getElementById('expiryTimer')) {
    summaryContent.appendChild(timerEl);
  }

  expiryInterval = setInterval(() => {
    const now = Date.now();
    const timeLeft = Math.floor((expiryTime - now) / 1000);
    
    const min = Math.floor(timeLeft / 60);
    const sec = timeLeft % 60;
    
    if (timeLeft <= 0) {
      clearInterval(expiryInterval);
      timerEl.textContent = "Session expired. Please restart.";
      alert("Your booking session has expired. Please start again.");
      location.reload();
      return;
    }
    
    timerEl.textContent = `Complete payment within ${min}:${sec.toString().padStart(2, '0')}`;
  }, 1000);
}

document.getElementById('checkBtn').addEventListener('click',async()=>{

  errorBox.classList.add('hidden');

  const guests=parseInt(document.getElementById('guestCount').value);
  const roomsRequested=parseInt(document.getElementById('roomCount').value);
  const checkin=document.getElementById('checkin').value;
  const checkout=document.getElementById('checkout').value;

  if(!checkin || !checkout || new Date(checkin)>=new Date(checkout)){
    showError("Please select valid dates.");
    return;
  }

  const inventory=await fetchInventory();
  const bookings=await fetchBookings(checkin,checkout);

  const roomList=document.getElementById('roomList');
  roomList.innerHTML='';

  inventory.forEach(room => {
    const rt = room.room; 
    const booked=countBooked(bookings,rt,checkin,checkout);
    const available=Math.max(0,room.qty-booked);
    const nights=(new Date(checkout)-new Date(checkin))/86400000;

    const div=document.createElement('div');
    div.className="border p-4 rounded bg-gray-50";

    div.innerHTML=`
      <div class="text-lg font-semibold">${room.label}</div>
      <div class="text-sm">Available: ${available}</div>
      <div class="flex gap-2 mt-3">
        <button class="bg-sky-600 text-white px-3 py-2 rounded acBtn">Book AC (₹${room.rateAC})</button>
        <button class="bg-gray-600 text-white px-3 py-2 rounded nonacBtn">Book Non-AC (₹${room.rateNonAC})</button>
      </div>
    `;

    if(available < roomsRequested){
      div.querySelectorAll('button').forEach(b=>{
        b.disabled=true;
        b.classList.add('opacity-40');
      });
    }

    function selectRoom(type){

      const pricing=calculateTotal(room,type,guests,nights,roomsRequested);

      selectedData={
        room:rt,
        label:room.label,
        type,
        checkin,
        checkout,
        guests,
        nights,
        roomsRequested,
        ...pricing
      };

      document.getElementById('guestFormSection').classList.remove('hidden');
      window.scrollTo({top:document.body.scrollHeight,behavior:'smooth'});
    }

    div.querySelector('.acBtn').addEventListener('click',()=>selectRoom("ac"));
    div.querySelector('.nonacBtn').addEventListener('click',()=>selectRoom("nonac"));

    roomList.appendChild(div);

  });

  document.getElementById('availabilitySection').classList.remove('hidden');

});

// OTP Logic
const sendOtpBtn = document.getElementById('sendOtpBtn');
const verifyOtpBtn = document.getElementById('verifyOtpBtn');
const mobileInput = document.getElementById('guestMobile');
const otpInput = document.getElementById('otpInput');
const otpSection = document.getElementById('otpSection');
const otpTimerEl = document.getElementById('otpTimer');
const payBtn = document.getElementById('payAdvanceBtn');

function startOtpResendTimer() {
  otpResendTimer = 60;
  sendOtpBtn.disabled = true;
  
  if (otpTimerInterval) clearInterval(otpTimerInterval);
  
  otpTimerInterval = setInterval(() => {
    otpResendTimer--;
    if (otpResendTimer <= 0) {
      clearInterval(otpTimerInterval);
      sendOtpBtn.textContent = 'Resend OTP';
      sendOtpBtn.disabled = false;
      otpTimerEl.textContent = '';
    } else {
      otpTimerEl.textContent = `Resend available in ${otpResendTimer}s`;
    }
  }, 1000);
}

sendOtpBtn.addEventListener('click', async () => {
  const mobile = mobileInput.value.trim();
  
  if (!/^[6-9][0-9]{9}$/.test(mobile)) {
    showError("Please enter a valid 10-digit mobile number.");
    return;
  }

  try {
    sendOtpBtn.textContent = 'Sending...';
    sendOtpBtn.disabled = true;
    
    const res = await fetch('/api/send-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mobile })
    });
    
    const data = await res.json();
    
    if (data.success) {
      otpSection.classList.remove('hidden');
      otpInput.focus();
      startOtpResendTimer();
    } else {
      showError(data.error || "Failed to send OTP.");
      sendOtpBtn.disabled = false;
      sendOtpBtn.textContent = 'Send OTP';
    }
  } catch (err) {
    console.error('OTP Send error:', err);
    showError("Failed to send OTP. Please try again.");
    sendOtpBtn.disabled = false;
    sendOtpBtn.textContent = 'Send OTP';
  }
});

verifyOtpBtn.addEventListener('click', async () => {
  const mobile = mobileInput.value.trim();
  const otp = otpInput.value.trim();
  
  if (otp.length !== 6) {
    showError("Please enter the 6-digit OTP.");
    return;
  }

  try {
    verifyOtpBtn.textContent = 'Verifying...';
    verifyOtpBtn.disabled = true;
    
    const res = await fetch('/api/verify-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mobile, otp })
    });
    
    const data = await res.json();
    
    if (data.success) {
      isMobileVerified = true;
      otpSection.classList.add('hidden');
      mobileInput.disabled = true;
      sendOtpBtn.classList.add('hidden');
      
      payBtn.disabled = false;
      payBtn.classList.remove('opacity-50', 'cursor-not-allowed');
      payBtn.textContent = 'Confirm & Pay 50% Advance';
      
      const successBadge = document.createElement('span');
      successBadge.className = "absolute right-3 top-2 text-green-600 font-bold";
      successBadge.textContent = "✓ Verified";
      mobileInput.parentElement.appendChild(successBadge);
      
    } else {
      showError(data.error || "Invalid OTP.");
      verifyOtpBtn.disabled = false;
      verifyOtpBtn.textContent = 'Verify';
    }
  } catch (err) {
    console.error('OTP Verify error:', err);
    showError("Failed to verify OTP. Please try again.");
    verifyOtpBtn.disabled = false;
    verifyOtpBtn.textContent = 'Verify';
  }
});

async function createBookingLock(selectedData, guestData){
  try{
    const response=await fetch('/api/booking-locks',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        room:selectedData.room,
        checkin:selectedData.checkin,
        checkout:selectedData.checkout,
        guests:selectedData.guests,
        roomsRequested:selectedData.roomsRequested,
        roomType:selectedData.type,
        customerName:guestData.name,
        customerMobile:guestData.mobile,
        customerEmail:guestData.email,
        total:selectedData.grandTotal,
        baseTotal:selectedData.baseTotal,
        extraCharge:selectedData.extraCharge,
        advanceAmount:Math.round((selectedData.grandTotal || 0) * 0.5),
        nights:selectedData.nights
      })
    });
    
    const result=await response.json();
    
    if(response.ok){
      currentLockId=result.lockId;
      selectedData.bookingId = result.bookingId;
      return {success:true, lockId:result.lockId, bookingId:result.bookingId, expiry:result.lockExpiry};
    }else{
      return {success:false, error:result.error};
    }
  }catch(err){
    console.error('Lock creation failed:', err);
    return {success:false, error:'Failed to create booking lock'};
  }
}

async function releaseBookingLock(){
  if(currentLockId){
    try{
      await fetch(`/api/booking-locks?lockId=${currentLockId}`,{method:'DELETE'});
      currentLockId=null;
    }catch(err){
      console.error('Lock release failed:', err);
    }
  }
}

document.getElementById('payAdvanceBtn').addEventListener('click',async()=>{

  const name=document.getElementById('guestName').value;
  const mobile=document.getElementById('guestMobile').value;
  const email=document.getElementById('guestEmail').value;

  if (!isMobileVerified) {
    showError("Please verify your mobile number with OTP first.");
    return;
  }

  if(!name || !mobile){
    showError("Name and Mobile required.");
    return;
  }

  if(!selectedData){
    showError("Please select a room first.");
    return;
  }

  guestData={name,mobile,email};

  const btn = document.getElementById('payAdvanceBtn');
  if (btn) {
    btn.disabled = true;
    btn.textContent = 'Creating lock...';
  }

  try {
    const lockResult=await createBookingLock(selectedData,guestData);
    
    if(!lockResult.success){
      showError(lockResult.error);
      return;
    }

    const advance = Math.round((selectedData.grandTotal || 0) * 0.5);

    const summary = document.getElementById('summaryContent');
    if (!summary) return;

    summary.innerHTML = `
      <div class="mb-4 p-3 bg-sky-50 border border-sky-100 rounded-lg">
        <span class="text-xs text-gray-500 uppercase font-bold tracking-wider">Booking ID</span>
        <div class="font-mono text-lg text-sky-700">${lockResult.bookingId.substring(0, 8).toUpperCase()}</div>
      </div>
      <div><strong>Guest:</strong> ${name}</div>
      <div><strong>Mobile:</strong> ${mobile}</div>
      <div><strong>Email:</strong> ${email || '-'}</div>
      <hr class="my-2"/>
      <div><strong>Room:</strong> ${selectedData.label} (${(selectedData.type || '').toUpperCase()})</div>
      <div><strong>Check-in:</strong> ${selectedData.checkin}</div>
      <div><strong>Check-out:</strong> ${selectedData.checkout}</div>
      <div><strong>Nights:</strong> ${selectedData.nights}</div>
      <div><strong>Rooms:</strong> ${selectedData.roomsRequested}</div>
      <div><strong>Base Amount:</strong> ₹${selectedData.baseTotal}</div>
      <div><strong>Extra Person:</strong> ₹${selectedData.extraCharge}</div>
      <div class="font-bold text-lg mt-2">Grand Total: ₹${selectedData.grandTotal}</div>
      <div class="text-green-700 font-semibold">Advance (50%): ₹${advance}</div>
      <button id="editBookingBtn" class="mt-3 text-blue-600 underline">Edit Booking</button>
    `;

    selectedData.advance = advance;

    const summarySection = document.getElementById('summarySection');
    if (summarySection) {
      summarySection.classList.remove('hidden');
      summarySection.scrollIntoView({ behavior: 'smooth' });
    }

    const editBtn = document.getElementById('editBookingBtn');
    if (editBtn) {
      editBtn.addEventListener('click', () => {
        if (summarySection) summarySection.classList.add('hidden');
      });
    }

    startExpiryTimer(lockResult.expiry);
  } catch (err) {
    console.error('Pay Advance button error:', err);
    showError('An error occurred. Please try again.');
  } finally {
    if (btn) {
      btn.disabled = false;
      btn.textContent = 'Confirm & Pay 50% Advance';
    }
  }
});

document.getElementById('cancelBookingBtn').addEventListener('click',async()=>{
  clearInterval(expiryInterval);
  await releaseBookingLock();
  location.reload();
});

document.getElementById('confirmPaymentBtn').addEventListener('click',async()=>{

  clearInterval(expiryInterval);

  try{
    const orderRes = await fetch('/api/create-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ amount: selectedData.advance })
    });

    const order = await orderRes.json();
    
    if (!orderRes.ok) {
      showError(`Payment system error: ${order.error || 'Failed to create order'}`);
      return;
    }

    const rzpKeyIdEl = document.getElementById('razorpayKeyId');
    const rzpKeyId = rzpKeyIdEl ? rzpKeyIdEl.dataset.key : "";

    const options = {
      key: rzpKeyId,
      amount: order.amount,
      currency: "INR",
      name: "Dolphin House Beach Resort",
      description: "50% Advance Booking",
      order_id: order.id,
      prefill: {
        name: guestData.name,
        email: guestData.email,
        contact: guestData.mobile
      },
      handler: async function (response) {
        const verifyRes = await fetch('/api/verify-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_order_id: response.razorpay_order_id,
            razorpay_signature: response.razorpay_signature,
            bookingData: { ...selectedData, ...guestData }
          })
        });

        const result = await verifyRes.json();

        if (result.success) {
          await sendNotifications(result.bookingId, 'payment_confirmed');
          window.location.href = `/thank-you?bookingId=${result.bookingId}`;
        } else {
          showError("Payment verification failed.");
          await releaseBookingLock();
        }
      }
    };

    const rzp = new window.Razorpay(options);
    
    rzp.on('payment.failed', function (response) {
      showError(`Payment failed: ${response.error.description}`);
    });

    rzp.open();

  } catch (err) {
    showError("Payment process failed. Please try again.");
    await releaseBookingLock();
  }

});

async function sendNotifications(bookingId, trigger){
  try{
    if(guestData.mobile){
      await fetch('/api/notifications',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({ bookingId, type:'whatsapp', trigger })
      });
    }
    
    if(guestData.email){
      await fetch('/api/notifications',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({ bookingId, type:'email', trigger })
      });
    }
  }catch(err){
    console.error('Notification sending failed:', err);
  }
}

</script>

</Layout>