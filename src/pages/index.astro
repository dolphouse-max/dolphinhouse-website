  <section class="section">
    <div class="container max-w-4xl mx-auto">
      <div class="text-center">
        <h2 class="heading">Frequently Asked Questions</h2>
        <p class="subtext">
          Quick answers about beach distance, pool access, booking, tariffs, parking, and Wi-Fi at Dolphin House.
        </p>
      </div>

      <div class="mt-10 space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-lg font-semibold text-gray-900">
              <span>{faq.question}</span>
              <span class="text-sky-600 transition-transform group-open:rotate-45">+</span>
