---
import Layout from "../layouts/Layout.astro";

const facilityIcons = {
  'Air-conditioned rooms & cottages': '❄️',
  'Attached bathrooms with geysers': '🚿',
  'Satellite TV': '📺',
  'Generator backup': '⚡',
  'Free Wi-Fi': '📶',
  'Car parking': '🅿️',
  'In-house restaurant': '🍽️',
  'Indoor swimming pool with waterfall': '🏊',
};
const facilities = Object.keys(facilityIcons);

const faqs = [
  {
    question: "How far is Dolphin House Beach Resort from Nagaon Beach?",
    answer:
      "Dolphin House Beach Resort is located just a 2-minute walk (around 200 meters) from the main Nagaon Beach entrance, making it convenient for quick beach access and a peaceful stay."
  },
  {
    question: "Does Dolphin House have a swimming pool?",
    answer:
      "Yes, Dolphin House has an indoor swimming pool with a waterfall feature for in-house guests."
  },
  {
    question: "What are the room tariffs at Dolphin House?",
    answer:
      "Room rates start from around Γé╣2000 for Non-AC rooms and Γé╣2300 for AC rooms, with family and deluxe room options also available."
  },
  {
    question: "Do you provide parking facilities?",
    answer:
      "Yes, we offer free on-site car parking for guests staying at the resort."
  },
  {
    question: "How can I make a booking?",
    answer:
      "You can book directly through our website booking page or contact us on WhatsApp for quick assistance and confirmation."
  },
  {
    question: "Is Wi-Fi available at the resort?",
    answer:
      "Yes, complimentary Wi-Fi is available for guests at Dolphin House."
  }
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout title="Beach Resort in Nagaon Alibaug with Swimming Pool | Dolphin House" description="Dolphin House Beach Resort: Best budget stay in Nagaon, Alibaug. Clean rooms with a private swimming pool near Nagaon Beach. Perfect for families!" image="/uploader/dolphinhouse-front-4.webp" ogType="hotel" faqSchema={faqSchema}>

  <!-- 🏖 Hero Section -->
  <section class="hero relative mb-20 overflow-hidden">
    <img 
      src="/uploader/dolphinhouse-front-4-700w.webp"
      srcset="/uploader/dolphinhouse-front-4-700w.webp 700w, /uploader/dolphinhouse-front-4-876w.webp 876w"
      sizes="100vw"
      alt="Dolphin House Beach Resort exterior near Nagaon Beach Alibaug"
      decoding="async" fetchpriority="high" class="hero-img" width="876" height="584" />
    <div class="hero-overlay">
     <h1 class="hero-title text-4xl md:text-5xl font-extrabold uppercase tracking-tight leading-tight">
          Best Beach Resort in Nagaon Alibaug with Swimming Pool: <span class="block text-sky-300">Dolphin House</span>
    </h1>
      <p class="hero-sub">Luxury Cottages & Rooms at Nagaon Beach, Alibaug</p>
    </div>
  </section>
  <p class="text-gray-600 mt-4 max-w-3xl mx-auto">
  Looking for the best beach resort in Nagaon Alibaug? Dolphin House Beach Resort offers AC rooms, family cottages, an indoor swimming pool, and direct booking just 2 minutes from Nagaon Beach. Perfect for weekend getaways from Mumbai and Pune, our resort combines comfort, affordability, and prime beach location.
  </p>
  <section class="container py-8 bg-gray-50 rounded-2xl my-10 border border-gray-200">
    <div class="flex flex-wrap justify-center gap-10 items-center text-center">
      <div class="max-w-[150px]">
        <img src="/gallery/dolphin-house-ratings.webp" alt="Justdial Users Choice Award 2026 Dolphin House" class="rounded-lg shadow-md mb-2" />
        <span class="text-xs font-bold text-gray-600 uppercase">Users' Choice 2026</span>
      </div>

      <div class="px-6 py-4">
        <span class="block text-3xl font-bold text-sky-600">4.1/5 ⭐</span>
        <span class="text-sm text-gray-500 font-medium">Google Reviews</span>
      </div>

      <div class="px-6 py-4">
        <span class="block text-3xl">🏊‍♂️</span>
        <span class="text-sm text-gray-500 font-medium">Indoor Pool & Waterfall</span>
      </div>
    </div>
  </section>
  <!-- 🌴 About -->
  <section class="section">
    <div class="container text-center">
      <h2 class="heading">Dolphin House: Your Luxury Resort in Alibaug Near Nagaon Beach</h2>
      <p class="subtext">
        Nestled just 2 minutes from the sea, Dolphin House is your gateway to peace, comfort, and
        tropical bliss. Enjoy luxury cottages, delicious dining, and the most serene beach in Alibaug.
      </p>
      <p class="text-gray-600 mt-4 text-base max-w-3xl mx-auto">
        Guests looking for the best resort near Nagaon Beach, Alibaug choose Dolphin House for family-friendly rooms, direct booking, and a peaceful stay close to the shore.
      </p>
      <a href="/rooms">AC rooms in Nagaon Alibaug</a>
      <p class="text-gray-600 mt-3 text-base max-w-3xl mx-auto">
        If you want a resort with swimming pool in Nagaon, Dolphin House offers indoor pool access, in-house dining, and easy beach access in one place.
      </p>
      <img 
        src="/uploader/nagaon-beach-332x221.webp" 
        srcset="/uploader/nagaon-beach-332x221.webp 332w, /uploader/nagaon-beach-800x533.webp 800w"
        sizes="(min-width: 1024px) 800px, 332px"
        alt="Nagaon Beach shoreline near Dolphin House Resort Alibaug" loading="lazy" class="rounded-xl shadow-xl mt-6 mx-auto w-full max-w-5xl" width="800" height="533" />
      <p class="text-gray-500 mt-4 text-base max-w-3xl mx-auto">
        Nagaon Beach is a hidden gem famous for clean sands and exciting water sports like parasailing, jet-skiing, and banana rides.
      </p>
    </div>
  </section>


  <section class="section">
    <div class="container max-w-6xl mx-auto grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="heading">Experience the Magic of Nagaon Beach, Alibaug</h2>
        <p class="text-lg text-gray-600 leading-relaxed mt-4">
          Choosing the right stay is about more than just a room-it's about the location. Dolphin House Beach Resort is perfectly situated just a <strong>2-minute walk from the pristine shores of Nagaon Beach</strong>, one of the cleanest and safest beaches in Alibaug. Known for its sparkling black sand and groves of Suru (Casuarina) trees, Nagaon is the go-to destination for travelers seeking both peace and adventure.
        </p>

        <h3 class="text-2xl font-bold text-gray-800 mt-8 mb-3">Why stay near Nagaon Beach?</h3>
        <p class="text-base text-gray-600 leading-relaxed">
          For the adventure seekers, <strong>Nagaon is the hub for water sports in Alibaug</strong>. From the adrenaline rush of parasailing and jet-skiing to family-friendly banana boat rides, there is something for everyone. If you prefer a quieter pace, the beach offers breathtaking sunset views and a calm atmosphere for a long evening stroll. Its unique flat surface makes it incredibly safe for children to play and swim.
        </p>

        <h3 class="text-2xl font-bold text-gray-800 mt-8 mb-3">Explore Beyond the Shore</h3>
        <p class="text-base text-gray-600 leading-relaxed">
          While Nagaon is the star attraction, staying at Dolphin House puts you in the heart of Alibaug's coastal beauty. You are just a short drive away from the historic <strong>Revdanda Fort</strong>, the famous <strong>Akshi Beach</strong>, and the local markets where you can experience authentic <strong>Konkani culture</strong>.
        </p>
        <p class="text-base text-gray-600 leading-relaxed mt-4">
          After a day of exploring the salty waves and local sights, retreat to our resort for a dip in our <a href="/rooms" class="font-semibold text-sky-600 hover:underline">indoor swimming pool</a> and a taste of our famous home-style seafood. Whether you are planning a quick weekend getaway from Mumbai or Pune, or a long family vacation, our proximity to the beach ensures you spend less time traveling and more time relaxing.
        </p>
      </div>

      <div>
        <img
          src="/uploader/nagaon-beach.webp"
          alt="Nagaon Beach water sports near Dolphin House Resort Alibaug"
          class="rounded-3xl shadow-xl w-full h-full object-cover"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section class="bg-sky-50 p-6 rounded-2xl border border-sky-100 my-10 max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-sky-900 mb-3">Expert Alibaug Travel Tips</h2>
    <p class="text-gray-700 leading-relaxed">
      Make the most of your trip! Whether you are visiting for a weekend or a long vacation, knowing the local secrets makes all the difference. For a complete list of sightseeing spots, hidden beaches, and a guide to the best
      <a href="https://hotelsinalibaug.in" target="_blank" rel="noopener noreferrer" class="text-sky-600 font-bold hover:underline">
        Hotels in Alibaug
      </a>,
      check out our dedicated travel portal. It's your one-stop shop for planning every detail of your Nagaon and Alibaug stay.
    </p>
  </section>

  <section class="my-10 max-w-5xl mx-auto rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-2xl font-bold text-gray-900 mb-3">Planning for a Family or Group Trip?</h2>
    <p class="text-gray-700 leading-relaxed">
      If you are comparing beaches, deciding what to do with kids, or choosing the right stay for a larger group, read our
      <a href="/alibaug-family-group-guide-2026" class="font-bold text-sky-600 hover:underline">Alibaug families and groups guide</a>
      for a practical 2026 overview of Nagaon Beach, activities, local food, and stay planning.
    </p>
  </section>

  <section class="my-10 max-w-5xl mx-auto rounded-2xl border border-cyan-100 bg-cyan-50 p-6 shadow-sm">
    <h2 class="text-2xl font-bold text-cyan-950 mb-3">Want to See Dolphins in Alibaug?</h2>
    <p class="text-gray-700 leading-relaxed">
      Most visitors are told they can spot dolphins right from the beach, but that is rarely how it works. Read our
      <a href="/dolphin-watching-alibaug-guide" class="font-bold text-sky-600 hover:underline">honest dolphin watching guide</a>
      to learn the best season, timing, and boat strategy for a real sighting.
    </p>
  </section>

  <section class="my-10 max-w-5xl mx-auto rounded-2xl border border-emerald-100 bg-emerald-50 p-6 shadow-sm">
    <h2 class="text-2xl font-bold text-emerald-950 mb-3">Why Stay in Nagaon Instead of Alibaug City?</h2>
    <p class="text-gray-700 leading-relaxed">
      If you want a cleaner beach, easier water sports access, and a quieter stay, read our
      <a href="/why-smart-travelers-choose-nagaon" class="font-bold text-sky-600 hover:underline">Nagaon vs Alibaug city guide</a>
      before you book.
    </p>
  </section>

  <section class="my-10 max-w-5xl mx-auto rounded-2xl border border-sky-100 bg-sky-50 p-6 shadow-sm">
    <h2 class="text-2xl font-bold text-sky-950 mb-3">Looking for a Beach Resort in Nagaon Alibaug?</h2>
    <p class="text-gray-700 leading-relaxed">
      If you want a stay close to the shoreline with AC rooms, family cottages, and a swimming pool, read our
      <a href="/beach-resort-in-nagaon-alibaug" class="font-bold text-sky-600 hover:underline">complete beach resort in Nagaon Alibaug guide</a>
      to see why Dolphin House is a strong fit for families, couples, and groups.
    </p>
  </section>

  <section class="my-10 max-w-5xl mx-auto rounded-2xl border border-cyan-100 bg-cyan-50 p-6 shadow-sm">
    <h2 class="text-2xl font-bold text-cyan-950 mb-3">Want a Resort with Swimming Pool in Alibaug?</h2>
    <p class="text-gray-700 leading-relaxed">
      If pool access matters as much as beach access, read our
      <a href="/resort-with-swimming-pool-alibaug" class="font-bold text-sky-600 hover:underline">resort with swimming pool in Alibaug guide</a>
      to see why Dolphin House is a strong choice for families and weekend travelers.
    </p>
  </section>

  <section class="my-10 max-w-5xl mx-auto rounded-2xl border border-sky-100 bg-white p-6 shadow-sm">
    <h2 class="text-2xl font-bold text-gray-900 mb-3">Coming with Family, Friends, or a Team?</h2>
    <p class="text-gray-700 leading-relaxed">
      <a href="/group-corporate-bookings" class="font-bold text-sky-600 hover:underline">Planning a group trip? Check our Group Packages.</a>
      We offer dedicated stay options for family reunions, friends' weekends, and corporate offsites near Nagaon Beach.
    </p>
  </section>

  <!-- 🏠 Rooms -->
  <section class="section bg-sky-50">
    <div class="container text-center">
      <h2 class="heading">Stay at Dolphin House</h2>
      <p class="subtext">
        Choose from elegant cottages and spacious family rooms — perfect for couples, families, and groups.
      </p>

      <div class="grid md:grid-cols-2 gap-10 mt-10">
        <div class="card hover-glow">
          <img 
            src="/uploader/hotel-front-1-480x320.webp"
            srcset="/uploader/hotel-front-1-480x320.webp 480w, /uploader/hotel-front-1-960x640.webp 960w"
            sizes="(min-width: 768px) 480px, 100vw"
            alt="Dolphin House Beach Resort in Nagaon Alibaug with swimming pool and cottages" loading="lazy" class="card-img" width="960" height="640" />
          <div class="card-overlay">
            <h3 class="card-title">Resort View</h3>
          </div>
        </div>
        <div class="card hover-glow">
          <img 
            src="/uploader/swimming-pool1-480x320.webp"
            srcset="/uploader/swimming-pool1-480x320.webp 480w, /uploader/swimming-pool1-960x640.webp 960w"
            sizes="(min-width: 768px) 480px, 100vw"
            alt="Indoor swimming pool at Dolphin House Resort Nagaon Alibaug" loading="lazy" class="card-img" width="960" height="640" />
          <div class="card-overlay">
            <h3 class="card-title">Indoor Swimming Pool</h3>
          </div>
        </div>
      </div>

      <a href="/rooms" class="btn-primary mt-10 inline-block">View All Rooms & Tariffs</a>
    </div>
  </section>

  <!-- 💎 Facilities -->
  <section class="section dark-section">
    <div class="container text-center">
      <h2 class="heading text-white">Facilities You’ll Love</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-10">
        {facilities.map((item) => (
          <div class="facility-card hover-lift">
            <span class="text-3xl">{facilityIcons[item]}</span>
            <p class="text-lg font-medium mt-2">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 📍 Location -->
  <section class="section">
    <div class="container max-w-4xl mx-auto">
      <h2 class="heading">How to Reach Dolphin House</h2>
      <ul class="reach-list mt-6">
        <li>✈️ <strong>Nearest Airport:</strong> Mumbai (107 km), Pune (153 km)</li>
        <li>🚆 <strong>Nearest Railway Station:</strong> Pen (35 km)</li>
        <li>🚌 <strong>Bus Stand:</strong> Nagaon (1 km), Alibaug (8 km)</li>
        <li>⛴️ <strong>By Ferry:</strong> Catamarans from Gateway of India to Mandwa Jetty</li>
      </ul>
    </div>
  </section>

  <!-- 📞 CTA -->
  <section class="section cta-section text-center">
    <h2 class="heading text-white">Ready to Book Your Stay?</h2>
    <p class="text-lg mb-6 text-white/90">
      Contact us for direct bookings, best rates, and instant confirmation.
    </p>
    <p class="mb-2 text-white/80">Nagaon Beach Road, Nagaon, Alibaug, Maharashtra</p>
    <p class="mb-2 text-white/80">📞 8554871073 / 9769766678 / 7276171735</p>
    <p class="mb-8 text-white/80">✉ contact@dolphinhouse-alibaug.com</p>
    <a href="https://wa.me/+917208993889" class="btn-light">
      💬 WhatsApp Us Now
    </a>
  </section>
<!-- 🧠 JSON-LD Structured Data for Google Rich Results -->
