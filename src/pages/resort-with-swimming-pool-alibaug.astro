---
import Layout from "../layouts/Layout.astro";

const poolFeatures = [
  "Indoor swimming pool with waterfall",
  "Clean and well-maintained pool area",
  "Suitable for families and kids",
  "Comfortable seating and relaxing atmosphere",
  "Easy access from rooms"
];

const getawayReasons = [
  "Mumbai to Alibaug weekend trips",
  "Pune to Alibaug short vacations",
  "Family holidays and group stays"
];

const resortBenefits = [
  "Prime location near Nagaon Beach",
  "Affordable pricing compared to luxury resorts",
  "Family-friendly environment",
  "Direct booking benefits",
  "Trusted by repeat guests"
];
---

<Layout
  title="Resort with Swimming Pool in Alibaug | Dolphin House Nagaon"
  description="Book a resort with swimming pool in Alibaug at Dolphin House Nagaon. Enjoy indoor pool, AC rooms, beach access, and family-friendly stay near Nagaon Beach."
  image="/uploader/swimming-pool1.webp"
  canonical="https://dolphinhouse-alibaug.com/resort-with-swimming-pool-alibaug"
  ogType="article"
>
  <section class="relative overflow-hidden rounded-[2rem] bg-gradient-to-br from-cyan-950 via-sky-700 to-sky-400 px-6 py-16 text-white shadow-2xl">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.25),transparent_35%)]"></div>
    <div class="relative grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <p class="text-sm uppercase tracking-[0.28em] text-white/70">Pool Stay Guide</p>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight md:text-6xl">
          Best Resort with Swimming Pool in Alibaug
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-relaxed text-white/90 md:text-xl">
          Looking for a resort with swimming pool in Alibaug? Dolphin House in Nagaon offers an indoor pool, comfortable rooms, and a relaxing stay just minutes from the beach, perfect for families and weekend travelers.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/booking" class="btn-light">Book Direct</a>
          <a href="/rooms" class="rounded-full border border-white/60 px-6 py-3 font-semibold text-white transition hover:bg-white hover:text-sky-900">
            View Rooms
          </a>
        </div>
      </div>

      <figure class="overflow-hidden rounded-[1.75rem] border border-white/20 bg-white/10 backdrop-blur-sm">
        <img
          src="/uploader/swimming-pool1.webp"
          alt="Indoor swimming pool at Dolphin House resort in Nagaon Alibaug"
          class="h-full w-full object-cover"
          width="1600"
          height="1067"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-5xl">
      <h2 class="heading text-left">Why Choose a Resort with Swimming Pool in Alibaug</h2>
      <div class="space-y-5 text-base leading-relaxed text-gray-700 md:text-lg">
        <p>
          When visiting Alibaug, having access to a swimming pool enhances your stay, especially for families and groups. While beaches offer natural beauty, a pool provides a safe and controlled environment for relaxation and fun.
        </p>
        <p>
          It is especially useful during high tide, crowded beach hours, or for guests who prefer privacy.
        </p>
      </div>
    </div>
  </section>

  <section class="section rounded-3xl border border-sky-100 bg-white shadow-sm">
    <div class="container max-w-5xl">
      <h2 class="heading text-left">About Dolphin House Swimming Pool Experience</h2>
      <div class="space-y-5 text-base leading-relaxed text-gray-700 md:text-lg">
        <p>
          Dolphin House offers an indoor swimming pool with a waterfall feature, making it a unique and enjoyable experience for guests.
        </p>
        <p>
          The pool is designed for both adults and children, ensuring a safe and relaxing environment throughout your stay.
        </p>
        <p>
          Guests who want a <a href="/beach-resort-in-nagaon-alibaug" class="font-semibold text-sky-600 hover:underline">beach resort near Nagaon Alibaug</a> can enjoy the rare advantage of both easy beach access and a private indoor pool inside the resort.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-6xl">
      <h2 class="heading text-left">Key Features of Our Pool Resort</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {poolFeatures.map((feature) => (
          <div class="rounded-3xl border border-cyan-100 bg-cyan-50 p-6 shadow-sm">
            <p class="text-lg font-semibold leading-relaxed text-cyan-950">{feature}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section rounded-3xl border border-emerald-100 bg-emerald-50">
    <div class="container max-w-5xl">
      <h2 class="heading text-left">Stay Close to Beach + Pool Advantage</h2>
      <div class="space-y-5 text-base leading-relaxed text-gray-700 md:text-lg">
        <p>
          One of the biggest advantages of Dolphin House is that you do not have to choose between beach and pool.
        </p>
        <p>
          You get 2-minute access to Nagaon Beach and a private pool experience inside the resort.
        </p>
        <p>
          This combination makes it one of the best resorts with swimming pool in Alibaug, especially for guests comparing beach access with <a href="/rooms" class="font-semibold text-sky-600 hover:underline">family rooms and cottages in Alibaug</a> for short leisure trips.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-6xl">
      <h2 class="heading text-left">Ideal for Weekend Getaways</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {getawayReasons.map((reason) => (
          <div class="rounded-3xl border border-amber-100 bg-amber-50 p-6 shadow-sm">
            <p class="text-lg font-semibold leading-relaxed text-amber-950">{reason}</p>
          </div>
        ))}
      </div>
      <p class="mt-8 text-base leading-relaxed text-gray-700 md:text-lg">
        The presence of a swimming pool adds extra comfort and enjoyment to short trips.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-6xl">
      <h2 class="heading text-left">Why Choose Dolphin House Resort</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {resortBenefits.map((benefit) => (
          <div class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm">
            <p class="text-lg font-semibold leading-relaxed text-gray-900">{benefit}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container max-w-5xl rounded-[2rem] bg-gray-900 px-8 py-12 text-white">
      <h2 class="text-3xl font-bold">Plan Your Pool + Beach Stay</h2>
      <p class="mt-4 max-w-3xl text-white/80">
        Book your stay at Dolphin House Resort and enjoy the perfect mix of beach and pool experience in Alibaug.
      </p>
      <p class="mt-3 max-w-3xl text-white/80">
        Contact us directly for best rates and availability.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/booking" class="btn-light">Check Availability</a>
        <a href="/rooms" class="rounded-full border border-white/30 px-6 py-3 font-semibold text-white transition hover:bg-white hover:text-gray-900">
          Compare Room Options
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Hotel",
      "name": "Dolphin House Resort with Swimming Pool",
      "url": "https://dolphinhouse-alibaug.com/resort-with-swimming-pool-alibaug",
      "description": "Resort with swimming pool in Alibaug offering indoor pool, AC rooms, and beach access near Nagaon Beach.",
      "image": "https://dolphinhouse-alibaug.com/uploader/swimming-pool1.webp",
      "amenityFeature": [
        {
          "@type": "LocationFeatureSpecification",
          "name": "Indoor Swimming Pool",
          "value": true
        },
        {
          "@type": "LocationFeatureSpecification",
          "name": "Family Friendly",
          "value": true
        }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Alibaug",
        "addressRegion": "Maharashtra",
        "addressCountry": "IN"
      }
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Which resort in Alibaug has a swimming pool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dolphin House in Nagaon Alibaug offers an indoor swimming pool along with beach access and AC rooms."
          }
        },
        {
          "@type": "Question",
          "name": "Is pool access included in Dolphin House stay?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, guests staying at Dolphin House can enjoy access to the indoor swimming pool."
          }
        }
      ]
    }
  </script>
</Layout>
