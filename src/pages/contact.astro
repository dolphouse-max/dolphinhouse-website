---
import Layout from "../layouts/Layout.astro";

const googleMapsUrl = "https://www.google.com/maps/search/?api=1&query=18.61127534275847, 72.89728476867242";
---
<Layout title="Contact Dolphin House Beach Resort | Nagaon, Alibaug" description="Get directions, phone numbers, WhatsApp, and email for Dolphin House Beach Resort near Nagaon Beach, Alibaug. Ask about rooms, rates, and availability." image="/uploader/dolphinhouse-front-4.webp">

  <!-- 🌴 Hero Section -->
  <section class="relative mb-16">
    <img src="/uploader/dolphinhouse-front-4.webp" alt="Dolphin House Beach Resort contact and location in Nagaon Alibaug"
      class="w-full h-72 md:h-[480px] object-cover rounded-3xl shadow-lg" />
    <div class="absolute inset-0 bg-black/40 flex flex-col justify-center items-center rounded-3xl text-white text-center px-6">
      <h1 class="text-5xl font-extrabold mb-2 drop-shadow-xl">Contact Us</h1>
      <p class="text-lg text-gray-200 max-w-2xl">We’d love to hear from you — reach out for bookings, availability, or inquiries.</p>
    </div>
  </section>

  <!-- 🌺 Contact Info Card -->
  <section class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-10 mb-20">
    
    <div class="bg-white rounded-3xl shadow-xl p-8 border border-gray-100 hover:shadow-2xl transition duration-300">
      <h2 class="text-3xl font-bold text-gray-800 mb-6">Dolphin House Beach Resort</h2>
      <p class="text-gray-600 mb-6 leading-relaxed">
        Nestled near the peaceful Nagaon Beach, Alibaug — the perfect getaway for families and couples seeking luxury and tranquility.
      </p>

      <div class="space-y-4 text-gray-700">
        <div class="flex items-start space-x-3">
          <span class="text-2xl text-sky-600">📍</span>
          <p>Nagaon Beach Road, Nagaon — 402204, Alibaug, Raigad, Maharashtra</p>
        </div>

        <div class="flex items-start space-x-3">
          <span class="text-2xl text-sky-600">📞</span>
          <div>
            <p><a href="tel:+918554871073" class="text-sky-600 hover:underline">+91 8554871073</a></p>
            <p><a href="tel:+919769766678" class="text-sky-600 hover:underline">+91 7276171735</a></p>
            <p><a href="tel:+917276171735" class="text-sky-600 hover:underline">+91 7276171735</a></p>

          </div>
        </div>
        <div class="flex items-start space-x-3">
          <span class="text-2xl text-sky-600">💬</span>
          <div>
            <p><a href="https://wa.me/917208993889" class="text-sky-600 hover:underline">+91 7208993889</a></p>           
          </div>
        </div>
        
        <div class="flex items-start space-x-3">
          <span class="text-2xl text-sky-600">✉️</span>
          <p><a href="mailto:contact@dolphinhouse-alibaug.com" class="text-sky-600 hover:underline">contact@dolphinhouse-alibaug.com</a></p>
        </div>

        <div class="flex items-start space-x-3">
          <span class="text-2xl text-sky-600">🕒</span>
          <p>Open daily from 8:00 AM – 10:00 PM</p>
        </div>
      </div>

      <div class="flex items-center gap-4 mt-8">
        <a href="https://wa.me/+917208993889" target="_blank"
          class="inline-flex items-center gap-2 bg-green-500 text-white px-5 py-3 rounded-full font-semibold hover:bg-green-600 transition transform hover:scale-105">
          💬 WhatsApp
        </a>
        <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-sky-600 text-white px-5 py-3 rounded-full font-semibold hover:bg-sky-700 transition transform hover:scale-105">
          📍 Google Maps
        </a>
      </div>
    </div>

    <!-- 📍 Embedded Google Map -->
    <div class="rounded-3xl overflow-hidden shadow-lg border border-gray-200 h-[400px]">
      <iframe 
        src="https://www.google.com/maps?q=Dolphin+House+Beach+Resort+Alibag&output=embed"
        width="100%" 
        height="350" 
        style="border:0;border-radius:10px;" 
        allowfullscreen="" 
        loading="lazy">
      </iframe>
    </div>
  </section>

  <!-- 🌊 Optional Inquiry CTA -->
  <section class="text-center bg-sky-600 text-white rounded-3xl shadow-2xl p-12 mb-16">
    <h2 class="text-3xl font-extrabold mb-3">Have a Question or Want to Book Directly?</h2>
    <p class="text-lg mb-6">Call or WhatsApp us anytime — we’re happy to help you plan your perfect beach getaway!</p>
    <a href="tel:+918554871073"
       class="inline-block bg-white text-sky-600 font-bold text-lg px-8 py-4 rounded-full hover:bg-gray-100 transition transform hover:scale-105">
       📞 Call Now
    </a>
  </section>

  <!-- 🧭 Schema for LocalBusiness / Hotel -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["Hotel", "LocalBusiness"],
    "name": "Dolphin House Beach Resort",
    "alternateName": "Dolphin House Resort Nagaon Alibaug",
    "url": "https://dolphinhouse-alibaug.com/contact",

    "image": [
      "https://dolphinhouse-alibaug.com/uploader/dolphinhouse-front-4.webp",
      "https://dolphinhouse-alibaug.com/uploader/hotel-front-1.webp",
      "https://dolphinhouse-alibaug.com/uploader/swimming-pool1.webp"
    ],
    "description": "Contact Dolphin House Beach Resort in Nagaon, Alibaug — beachfront resort with AC cottages, restaurant, pool, and premium hospitality.",
    "telephone": "+91-8554871073",
    "email": "contact@dolphinhouse-alibaug.com",
    "priceRange": "₹2000 - ₹3800",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Nagaon Beach Road, Nagaon",
      "addressLocality": "Alibaug",
      "addressRegion": "Maharashtra",
      "postalCode": "402204",
      "addressCountry": "IN"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": "18.5830", "longitude": "72.9028" },
    "openingHours": "Mo-Su 08:00-22:00",
    "sameAs": [
      "https://www.google.com/maps/search/?api=1&query=18.5830,72.9028",
      "https://www.facebook.com/dolphinhousealibaug/",
      "https://www.instagram.com/dolphin_house_alibaug/"
    ],
    "hasMap": "https://www.google.com/maps/search/?api=1&query=18.5830,72.9028"
  }
  </script>

</Layout>
