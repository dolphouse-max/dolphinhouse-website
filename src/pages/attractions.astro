---
import Layout from "../layouts/Layout.astro";

const attractions = [
  {
    name: "Nagaon Beach",
    image: "/uploader/nagaon-beach.webp",
    alt: "Nagaon Beach in Alibaug near Dolphin House resort with water sports activities",
    description: "A pristine stretch of golden sand just 2 minutes from Dolphin House. Perfect for water sports like parasailing, jet skiing, and banana boat rides. Clean, safe, and ideal for families. One of the best places to visit in Alibaug, especially for water sports lovers and families staying near the beach.",
    distance: "2 min walk",
    activities: ["Water Sports", "Swimming", "Beach Walks"]
  },
  {
    name: "Alibaug Beach",
    image: "/uploader/alibaug-beach.webp",
    alt: "Alibaug Beach sunset views near Dolphin House resort in Alibaug",
    description: "The main town beach famous for its stunning sunset views and horseback rides along the shore. Lined with street food stalls and local vendors, it is perfect for an evening stroll. A popular attraction in Alibaug for sunset lovers and casual beach outings.",
    distance: "8 km",
    activities: ["Sunset Views", "Horse Rides", "Street Food"]
  },
  {
    name: "Kashid Beach",
    image: "/uploader/kashid-beach.webp",
    alt: "Kashid Beach near Alibaug and Dolphin House resort for peaceful day trips",
    description: "One of the most beautiful beaches in Konkan, known for its white sands, crystal-clear waters, and swaying casuarina trees. Less crowded and perfect for a peaceful day trip. A favorite among visitors looking for scenic beaches near Alibaug.",
    distance: "28 km",
    activities: ["Swimming", "Photography", "Beach Games"]
  },
  {
    name: "Kolaba Fort",
    image: "/uploader/kolaba-fort.webp",
    alt: "Kolaba Fort historical attraction in Alibaug near main beach area",
    description: "A historic 17th-century sea fort accessible by foot during low tide. Explore ancient temples, cannons, and enjoy panoramic views of the Arabian Sea from the ramparts. A must-visit historical attraction in Alibaug located near the main beach area.",
    distance: "9 km",
    activities: ["History", "Photography", "Trekking"]
  },
  {
    name: "Murud-Janjira Fort",
    image: "/uploader/murud-janjira-fort.webp",
    alt: "Murud-Janjira Fort day trip from Nagaon Alibaug near Dolphin House resort",
    description: "An unconquered island fortress from the 15th century, accessible only by boat. Marvel at its massive walls, cannons, and the engineering marvel that withstood numerous attacks. One of the most iconic historical places to visit near Nagaon Beach.",
    distance: "45 km",
    activities: ["Boat Ride", "History", "Photography"]
  },
  {
    name: "Mandwa Beach",
    image: "/uploader/mandwa-beach.webp",
    alt: "Mandwa Beach near Alibaug ferry route and Dolphin House resort",
    description: "A serene beach near the ferry jetty, offering beautiful views of Mumbai's skyline. Popular spot for water sports and a quick getaway from the city hustle. A convenient beach stop for travelers arriving from Mumbai.",
    distance: "15 km",
    activities: ["Ferry Rides", "Water Sports", "City Views"]
  },
  {
    name: "Revdanda Beach",
    image: "/uploader/revdanda-beach.webp",
    alt: "Revdanda Beach near Nagaon Alibaug and Dolphin House beach resort",
    description: "A hidden gem with soft black sand and calm waters, surrounded by coconut groves. Visit the nearby Revdanda Fort and Korlai Fort for a dose of Portuguese history. A peaceful coastal attraction for guests exploring beyond the main Alibaug beach belt.",
    distance: "22 km",
    activities: ["Beach Camping", "Fort Visits", "Fishing"]
  }
];
---

<Layout title="15 Best Places to Visit in Alibaug & Konkan (2026 Guide)" 
description="Plan your trip with our 2026 guide to Alibaug sightseeing. Top attractions like Nagaon Beach, Kolaba Fort, & Kashid Beach. Best things to do in Konkan near Mumbai."
 image="/uploader/nagaon-beach.webp">

  <section class="relative mb-12 overflow-hidden">
    <div class="relative h-[400px] bg-gradient-to-r from-sky-600 to-teal-500 rounded-3xl">
      <div class="absolute inset-0 bg-black/30 rounded-3xl"></div>
      <div class="relative max-w-6xl mx-auto px-6 h-full flex flex-col justify-center items-center text-center text-white">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-4 drop-shadow-lg">
          Best Places to Visit in Alibaug & Konkan
        </h1>
        <p class="text-xl md:text-2xl text-white/90 max-w-2xl">
          Discover beaches, forts, and day-trip attractions close to Dolphin House in Nagaon.
        </p>
      </div>
    </div>
  </section>

    <div class="max-w-4xl mx-auto p-6 bg-yellow-50 border-l-4 border-yellow-400 rounded-r-xl mb-10">
    <p class="text-gray-800 font-medium">
      📍 <strong>Traveler Tip:</strong> Staying at Dolphin House puts you within a 2-minute walk of Nagaon Beach. Most other <strong>Alibaug tourist attractions</strong> like Kolaba Fort and Revdanda are within a 20-minute drive, making us the perfect central base for your <strong>Konkan trip</strong>.
    </p>
  </div>
    <section class="max-w-3xl mx-auto text-center mt-6">
      <h2 class="text-2xl font-bold">
        Top Alibaug Sightseeing Attractions & Konkan Beaches
      </h2>

      <p class="text-gray-600 mt-3">
        Looking for the best places to visit in Alibaug? From clean beaches like 
        Nagaon Beach and Kashid Beach to historic forts like Kolaba Fort, 
        Alibaug offers a perfect mix of relaxation, adventure, and sightseeing.          Alibaug offers a perfect mix of relaxation, adventure, and sightseeing.
      </p>

      <p class="text-gray-600 mt-3">
        This guide covers top attractions, beaches, and things to do near Alibaug for families, couples, and weekend travelers.
      </p>
    </section>

  <section class="max-w-5xl mx-auto px-6 pb-12 text-center">
    <p class="text-lg text-gray-700 leading-relaxed">
      Looking for things to do in Alibaug near Nagaon Beach? From water sports at Nagaon Beach to historic forts like Kolaba and Murud-Janjira, Alibaug offers a mix of relaxation, adventure, and sightseeing. Staying at Dolphin House Beach Resort gives you easy access to the best beaches and attractions in the region.
    </p>
    <p class="text-base text-gray-600 leading-relaxed mt-4">
      Explore nearby stays like our <a href="/beach-resort-in-nagaon-alibaug" class="font-semibold text-sky-600 hover:underline">beach resort in Nagaon Alibaug</a>
      or relax at a <a href="/resort-with-swimming-pool-alibaug" class="font-semibold text-sky-600 hover:underline">resort with swimming pool in Alibaug</a>
      after your day trips.
    </p>
    <p class="text-base text-gray-600 leading-relaxed mt-3">
      If you are still deciding where to stay, compare our guides for a
      <a href="/resort-in-alibaug" class="font-semibold text-sky-600 hover:underline">resort in Alibaug</a>,
      <a href="/beach-resort-alibaug" class="font-semibold text-sky-600 hover:underline">beach resort Alibaug</a>, and
      <a href="/nagaon-beach-resort" class="font-semibold text-sky-600 hover:underline">Nagaon Beach resort</a>
      before finalizing your trip base.
    </p>
    <p class="text-sm text-gray-500 text-center">
    All attractions listed are located in Alibaug, Maharashtra, India (near Mumbai). 
    </p>
    <p class="text-base text-gray-600 leading-relaxed mt-3">
      Most of these attractions are located within 2 to 45 km from Nagaon Beach, making Dolphin House an ideal base for exploring Alibaug without long travel times.
    </p>
  </section>

  <h2 class="text-2xl font-bold text-center mt-10">
    Top Beaches and Historical Places in Alibaug
  </h2>
  <section class="max-w-7xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {attractions.map((place) => (
        <div class="attraction-card group">
          <div class="relative overflow-hidden rounded-t-2xl h-64">
            <img
              src={place.image}
              alt={place.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-sm font-semibold text-sky-700">
              {place.distance}
            </div>
          </div>

          <div class="p-6 bg-white">
            <h2 class="text-2xl font-bold text-gray-800 mb-3 group-hover:text-sky-600 transition">
              {place.name}
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              {place.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {place.activities.map((activity) => (
                <span class="activity-tag">
                  {activity}
                </span>
              ))}
            </div>
          </div>

          <div class="absolute inset-0 border-2 border-transparent group-hover:border-sky-400 rounded-2xl transition-colors duration-300 pointer-events-none"></div>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto mt-12">
  <h2 class="text-2xl font-bold text-center">
    Things to Do in Alibaug
  </h2>

  <ul class="mt-4 text-gray-600 space-y-2 text-center">
    <li>✔ Enjoy water sports at Nagaon Beach</li>
    <li>✔ Watch sunset at Alibaug Beach</li>
    <li>✔ Visit Kolaba Fort during low tide</li>
    <li>✔ Take a boat ride to Murud-Janjira Fort</li>
    <li>✔ Relax at Kashid Beach</li>
  </ul>
</section>

  <section class="max-w-5xl mx-auto px-6 pb-16">
   <div class="my-8 rounded-2xl border border-cyan-100 bg-cyan-50 p-6 shadow-sm">
      <h3 class="text-xl font-bold text-cyan-900 mb-2">🐬 Planning a Dolphin Tour?</h3>
      <p class="text-gray-700 mb-4">
        Sightings are best in the early morning near Nagaon and Murud. We recommend a specialized boat tour for the best experience.
