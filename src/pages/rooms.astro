---
import Layout from "../layouts/Layout.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the price of rooms at Dolphin House Beach Resort Alibaug?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Room prices at Dolphin House Beach Resort in Nagaon, Alibaug start from Rs. 2900 and vary based on room type, occupancy, and AC option."
      }
    },
    {
      "@type": "Question",
      "name": "How far are the rooms from Nagaon Beach?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All rooms are located around a 2-minute walk from Nagaon Beach."
      }
    },
    {
      "@type": "Question",
      "name": "Is this Dolphin House in Goa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. This website is for Dolphin House Beach Resort in Nagaon, Alibaug, Maharashtra."
      }
    }
  ]
};

const roomCategories = [
  {
    image: "/uploader/room-1.webp",
    alt: "Standard ac cottage room in Nagaon Alibaug near beach at Dolphin House resort",
    title: "Standard Room in Nagaon Alibaug Near Beach",
    type: "Non-AC / AC Available",
    description: "Ideal for couples or solo travelers looking for affordable rooms in Nagaon Alibaug near the beach. This room offers a comfortable stay with essential amenities just 2 minutes from Nagaon Beach.",
