---
import Layout from "../layouts/Layout.astro";

const roomCategories = [
  {
    image: "/uploader/room-1.webp",
    title: "Standard Room",
    type: "Non-AC / AC Available",
    description: "Ideal for couples or solo travelers — cozy and affordable stay near Nagaon Beach.",
    max: 2,
    area: 140,
    rateNonAC: 2900,
    rateAC: 3200,
    features: ["Queen Bed", "Attached Bathroom", "Wi-Fi", "TV", "Generator Backup"],
    videoUrl: "https://www.youtube.com/shorts/placeholder", // Placeholder link
    width: 1575,
    height: 1067
  },
  {
    image: "/uploader/room-2.webp",
    title: "Deluxe Room",
    type: "Non-AC / AC Available",
    description: "Spacious comfort with premium interiors, perfect for couples or small families.",
    max: 3,
    area: 160,
    rateNonAC: 3200,
    rateAC: 3500,
    features: ["King Bed", "Balcony View", "Hot Water", "TV", "Wi-Fi"],
     videoUrl: "https://youtube.com/shorts/9Kj58SEetik", // Add YouTube Short link here
    width: 1575,
    height: 1067
  },
  {
    image: "/uploader/room-5.webp",
    title: "Family Room",
    type: "Non-AC / AC Available",
    description: "A large, airy room for families with children or groups. Relax and enjoy together!",
    max: 4,
    area: 200,
    rateNonAC: 3500,
    rateAC: 4000,
    features: ["Double Beds", "Extra Person Option", "TV", "Wi-Fi", "Hot Water"],
    videoUrl: "", // Add YouTube Short link here
    width: 1600,
    height: 1086
  },
  {
    image: "/uploader/Room-9.webp",
    title: "Deluxe Family Room",
    type: "Non-AC / AC Available",
    description: "Luxury family suite with pool view and private balcony. Perfect for long stays.",
    max: 5,
    area: 300,
    rateNonAC: 4000,
    rateAC: 4500,
    features: ["King Bed", "Private Balcony", "Pool View", "TV", "Wi-Fi"],
    videoUrl: "",
    width: 1600,
    height: 1086
  },
];
---

<Layout title="Rooms in Nagaon Alibaug | AC, Family & Deluxe Rooms" description="Compare AC, non-AC, family, and deluxe family rooms at Dolphin House near Nagaon Beach, Alibaug. View occupancy, amenities, and direct booking options." image="/uploader/room-9.webp" ogType="hotel">

  <!-- Hero Section -->
  <section class="relative mb-16">
    <img 
      src="/uploader/hotel-front-1.webp" 
      srcset="/uploader/hotel-front-1-480x320.webp 480w, /uploader/hotel-front-1-960x640.webp 960w, /uploader/hotel-front-1.webp 1267w"
      sizes="(min-width: 1024px) 1267px, (min-width: 768px) 960px, 100vw"
      alt="Dolphin House Resort Rooms" 
      class="w-full h-80 md:h-[450px] object-cover rounded-3xl shadow-xl" 
      width="1267" height="1067" decoding="async" fetchpriority="high" />
    <div class="absolute inset-0 bg-black/50 flex items-center justify-center rounded-3xl">
      <h1 class="text-4xl md:text-6xl font-extrabold text-white text-center tracking-tight">
        Rooms & Tariffs
      </h1>
    </div>
  </section>

  <!-- Summary Section -->
  <section class="text-center mb-16 max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-gray-800 mb-4">Relax in Comfort by the Beach</h2>
    <p class="text-lg text-gray-600 leading-relaxed">
      Choose from our range of cozy, well-furnished rooms and cottages — each designed for comfort, peace, and convenience. 
      Enjoy your vacation just <strong>2 minutes’ walk from Nagaon Beach</strong>, with all modern amenities you expect from a top Alibaug resort.
    </p>
  </section>

  <!-- Rooms Grid -->
  <section class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
    {roomCategories.map(room => (
      <div class="group bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100 hover:shadow-2xl transition transform hover:-translate-y-1">
        <div class="relative overflow-hidden">
          <img 
            src={room.image} 
            alt={room.title} 
            class="w-full h-64 object-cover group-hover:scale-110 transition duration-500" 
            width={room.width} height={room.height} loading="lazy" decoding="async" />
          <div class="absolute top-0 left-0 bg-sky-600 text-white px-3 py-1 text-sm rounded-br-xl shadow-md">
            {room.type}
          </div>
        </div>
        <div class="p-6 flex flex-col justify-between h-[320px]">
          <div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">{room.title}</h3>
            <p class="text-gray-600 text-sm mb-3">{room.description}</p>
            <ul class="text-sm text-gray-500 space-y-1">
              <li>👥 <strong>Max Guests:</strong> {room.max}</li>
              <li>📏 <strong>Size:</strong> {room.area} sq.ft</li>
              <li>💰 <strong>Tariff:</strong> ₹{room.rateNonAC} (Non-AC) / ₹{room.rateAC} (AC)</li>
            </ul>
          </div>
          <div class="mt-4 flex flex-col gap-3">
            <div class="flex justify-between items-center text-xs text-gray-500">
               <span>Max Guests: {room.max}</span>
               <span class="italic">+ ₹700 / extra person</span>
            </div>
            <div class="flex gap-2">
              <a href="/booking" class="flex-1 bg-sky-600 text-white font-semibold py-2 rounded-lg hover:bg-sky-700 transition text-sm shadow-md text-center">
                Book Now
              </a>
              {room.videoUrl && (
                <a href={room.videoUrl} target="_blank" rel="noopener noreferrer" class="flex-1 border border-sky-600 text-sky-600 font-semibold py-2 rounded-lg hover:bg-sky-50 transition text-sm shadow-sm text-center flex items-center justify-center gap-1">
                  <span>▶</span> 360° Tour
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- Amenities Section -->
  <section class="mt-20 bg-blue-50/50 border border-blue-100 rounded-3xl p-10 shadow-inner text-center">
    <h2 class="text-3xl font-bold text-gray-800 mb-6">Room Features & Facilities</h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 text-gray-700">
      <div class="feature-card">🛏️ Air-conditioned Rooms</div>
      <div class="feature-card">📺 Satellite TV</div>
      <div class="feature-card">💧 Attached Bathrooms</div>
      <div class="feature-card">🌐 Free Wi-Fi</div>
      <div class="feature-card">⚡ Generator Backup</div>
      <div class="feature-card">🏊 Indoor Swimming Pool</div>
      <div class="feature-card">🍽️ In-house Restaurant</div>
      <div class="feature-card">🚗 Car Parking</div>
    </div>
  </section>
  <section class="mt-20 py-12 bg-white rounded-3xl border border-gray-100 shadow-sm">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-gray-800 mb-8 text-center">Guest Experiences</h2>

      <div class="bg-sky-50 p-8 rounded-2xl relative">
        <span class="absolute top-4 left-4 text-6xl text-sky-200 font-serif">“</span>

        <div class="relative z-10">
          <p class="text-lg text-gray-700 italic leading-relaxed mb-6">
            "The fantastic place to stay-I can't even call it a hotel or a cottage because it seems like home to my family and myself. The meal was fantastic and the services provided by the staff are unmatched. This is very much close to beach, just a 2 mins walking distance."
          </p>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-sky-600 rounded-full flex items-center justify-center text-white font-bold text-xl">
              R
            </div>
            <div>
              <h4 class="font-bold text-gray-900">Rakesh Rane</h4>
              <div class="flex text-yellow-400 text-sm">
                ★★★★★ <span class="ml-2 text-gray-500 font-normal">Google Review</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="https://www.google.com/search?q=Dolphin+House+Beach+Resort+Reviews" target="_blank" rel="noopener noreferrer" class="text-sky-600 font-semibold hover:underline">
          Read more reviews on Google →
        </a>
      </div>
    </div>
  </section>

  <!-- Pool Gallery -->
  <section class="mt-20">
    <h2 class="text-3xl font-bold text-gray-800 mb-8 text-center">Indoor Swimming Pool</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <img 
        src="/uploader/swimming-pool1.webp" 
        srcset="/uploader/swimming-pool1-480x320.webp 480w, /uploader/swimming-pool1-960x640.webp 960w, /uploader/swimming-pool1.webp 1600w" 
        sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw" 
        alt="Pool 1" 
        class="rounded-2xl shadow-md w-full h-56 object-cover hover:scale-105 transition" 
        width="1600" height="945" loading="lazy" decoding="async" />
      <img 
        src="/uploader/swimming-pool1_1.webp" 
        alt="Pool 2" 
        class="rounded-2xl shadow-md w-full h-56 object-cover hover:scale-105 transition" 
        width="1600" height="943" loading="lazy" decoding="async" />
      <img 
        src="/uploader/swimming-pool2.webp" 
        alt="Pool 3" 
        class="rounded-2xl shadow-md w-full h-56 object-cover hover:scale-105 transition" 
        width="1600" height="945" loading="lazy" decoding="async" />
      <img 
        src="/uploader/swimming-pool3.webp" 
        alt="Pool 4" 
        class="rounded-2xl shadow-md w-full h-56 object-cover hover:scale-105 transition" 
        width="1600" height="943" loading="lazy" decoding="async" />
    </div>
  </section>

</Layout>


