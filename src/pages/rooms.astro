    area: 140,
    rateNonAC: 2900,
    rateAC: 3200,
    features: ["Queen Bed", "Attached Bathroom", "Wi-Fi", "TV", "Generator Backup"],
    videoUrl: "https://www.youtube.com/shorts/placeholder",
    width: 1575,
    height: 1067
  },
  {
