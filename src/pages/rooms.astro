      </details>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the price of rooms at Dolphin House Beach Resort Alibaug?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Room prices at Dolphin House Beach Resort in Nagaon, Alibaug start from Rs. 2900 and vary based on room type and AC option."
          }
        },
        {
          "@type": "Question",
          "name": "Is this Dolphin House in Goa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. This website is for Dolphin House Beach Resort in Nagaon, Alibaug, Maharashtra."
          }
        },
        {
          "@type": "Question",
          "name": "How far are the rooms from Nagaon Beach?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All rooms are located just a 2-minute walk from Nagaon Beach."
          }
        },
        {
          "@type": "Question",
          "name": "Do rooms include access to swimming pool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, all guests can use the indoor swimming pool during their stay."
          }
        }
      ]
    }
  </script>

  <script type="application/ld+json">
