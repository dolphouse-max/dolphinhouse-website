    "addressRegion": "Maharashtra",
    "postalCode": "402204",
    "addressCountry": "IN"
  },
  "priceRange": "INR 2900 - 4500",
  "containsPlace": [
    {
      "@type": "HotelRoom",
      "name": "Standard AC Room",
      "occupancy": { "@type": "QuantitativeValue", "value": 2 }
    },
    {
      "@type": "HotelRoom",
      "name": "Family Deluxe Room",
      "occupancy": { "@type": "QuantitativeValue", "value": 4 }
    }
  ]
}
