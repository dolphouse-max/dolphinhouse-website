    title: "Deluxe Room Near Nagaon Beach Alibaug",
    type: "Non-AC / AC Available",
    description: "A deluxe room near Nagaon Beach designed for couples or small families who want extra comfort, better space, and a relaxing stay near the beach in Alibaug.",
    max: 3,
    area: 160,
    rateNonAC: 3200,
    rateAC: 3500,
    features: ["King Bed", "Balcony View", "Hot Water", "TV", "Wi-Fi"],
    videoUrl: "https://youtube.com/shorts/9Kj58SEetik",
    width: 1575,
    height: 1067
  },
  {
    image: "/uploader/room-5.webp",
    alt: "Family cottage room in Alibaug near beach at Dolphin House for 4 guests",
    title: "Family Room in Alibaug Near Beach for 4 Guests",
    type: "Non-AC / AC Available",
    description: "A practical family room in Alibaug for guests who want more space, easy beach access, and a comfortable stay near Nagaon Beach with children or a small group.",
    max: 4,
    area: 200,
    rateNonAC: 3500,
    rateAC: 4000,
    features: ["Double Beds", "Extra Person Option", "TV", "Wi-Fi", "Hot Water"],
    videoUrl: "",
    width: 1600,
    height: 1086
  },
  {
    image: "/uploader/Room-9.webp",
    alt: "Deluxe family room near Nagaon Beach with pool view at Dolphin House Alibaug",
    title: "Deluxe Family Room in Alibaug Near Nagaon Beach for 4 Guests",
    type: "Non-AC / AC Available",
    description: "Ideal for larger families or groups looking for a stay near beach Alibaug with more room, pool views, and added comfort for longer or more relaxed vacations.",
    max: 5,
    area: 300,
    rateNonAC: 4000,
    rateAC: 4500,
    features: ["King Bed", "Private Balcony", "Pool View", "TV", "Wi-Fi"],
